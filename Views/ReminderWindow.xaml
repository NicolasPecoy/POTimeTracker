<Window x:Class="POTimeTracker.Views.ReminderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recordatorio"
        Width="360"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual">
    <Border CornerRadius="16"
            Background="{StaticResource BgSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="10"
                    Width="42"
                    Height="42"
                    Margin="0,0,12,0">
                <TextBlock Text="PO"
                           FontWeight="Bold"
                           FontSize="15"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Recordatorio de horas"
                           Style="{StaticResource HeaderTitle}"
                           FontSize="16"/>
                <TextBlock Text="No te olvides de llenar las horas del dia 🙂."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <Button Grid.Column="2"
                    Style="{StaticResource GhostButton}"
                    Content="X"
                    Width="28"
                    Height="28"
                    Padding="0"
                    VerticalAlignment="Top"
                    Click="Close_Click"/>
        </Grid>
    </Border>
</Window>
