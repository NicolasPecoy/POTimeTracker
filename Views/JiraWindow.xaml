<Window x:Class="POTimeTracker.Views.JiraWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jira - PO Time Tracker"
        Width="420" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Window.RenderTransform>
        <TranslateTransform/>
    </Window.RenderTransform>

    <Border CornerRadius="16"
            Background="{StaticResource BgSurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid>
            <!-- ═══════════ CONFIG VIEW ═══════════ -->
            <Border x:Name="ConfigView" Visibility="Visible" CornerRadius="16">
                <StackPanel Margin="28,24">

                    <!-- Logo + Title -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Border CornerRadius="10" Width="42" Height="42" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF0052CC" Offset="0"/>
                                    <GradientStop Color="#FF2684FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="J" FontWeight="Bold" FontSize="22"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Jira" Style="{StaticResource HeaderTitle}" FontSize="18"/>
                            <TextBlock Text="Configurar conexion" Style="{StaticResource HeaderSubtitle}"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="URL DE JIRA (ej: https://empresa.atlassian.net)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtBaseUrl" Style="{StaticResource ModernTextBox}"
                             Text="https://invenzis.atlassian.net" Margin="0,0,0,14"/>

                    <TextBlock Text="EMAIL" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtEmail" Style="{StaticResource ModernTextBox}" Margin="0,0,0,14"/>

                    <TextBlock Text="API TOKEN" Style="{StaticResource LabelStyle}"/>
                    <PasswordBox x:Name="txtApiToken" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,6"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,14"
                               TextWrapping="Wrap">
                        Genera tu token en: Cuenta Atlassian → Seguridad → API tokens
                    </TextBlock>

                    <TextBlock Text="PROYECTO POR DEFECTO (opcional)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtDefaultProject" Style="{StaticResource ModernTextBox}"
                             Margin="0,0,0,18"/>

                    <!-- Debug proxy toggle -->
                    <Border Background="{StaticResource BgElevatedBrush}" CornerRadius="6"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Padding="10,7" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="PROXY DE DEBUG" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock x:Name="txtProxyUrl" Text="http://localhost:8888"
                                           FontSize="11" FontFamily="Consolas"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="chkProxy" Grid.Column="1"
                                      VerticalAlignment="Center"
                                      ToolTip="Enrutar trafico por Fiddler / Charles en :8888"
                                      Checked="ChkProxy_Changed"
                                      Unchecked="ChkProxy_Changed"/>
                        </Grid>
                    </Border>

                    <Button x:Name="btnConnect" Style="{StaticResource AccentButton}"
                            Content="Conectar a Jira" Click="BtnConnect_Click" Height="42"/>

                    <TextBlock x:Name="txtConfigError" Foreground="{StaticResource RedBrush}"
                               FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center"
                               Margin="0,12,0,0" Visibility="Collapsed"/>

                    <StackPanel x:Name="ConfigLoading" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,12,0,0" Visibility="Collapsed">
                        <TextBlock Text="Conectando..." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══════════ MAIN VIEW ═══════════ -->
            <StackPanel x:Name="MainView" Visibility="Collapsed">

                <!-- HEADER -->
                <Border Padding="18,14" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1" CornerRadius="16,16,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{StaticResource BgElevated}" Offset="0"/>
                            <GradientStop Color="{StaticResource BgSurface}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <Border CornerRadius="8" Width="32" Height="32" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF0052CC" Offset="0"/>
                                        <GradientStop Color="#FF2684FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="J" FontWeight="Bold" FontSize="15" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Jira" Style="{StaticResource HeaderTitle}"/>
                                <TextBlock x:Name="txtUserDisplay" Text="usuario" Style="{StaticResource HeaderSubtitle}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center">
                            <Border Background="{StaticResource GreenSoftBrush}" CornerRadius="12" Padding="8,3" Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Fill="{StaticResource GreenBrush}" Margin="0,0,5,0"/>
                                    <TextBlock Text="Online" Foreground="{StaticResource GreenBrush}"
                                               FontSize="11" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Button Style="{StaticResource GhostButton}" Content="&#9881;" Width="28" Height="28"
                                    Padding="0" Click="BtnSettings_Click" ToolTip="Configuracion Jira"
                                    Margin="0,0,4,0" FontSize="14"/>
                            <Button Style="{StaticResource GhostButton}" Content="--" Width="28" Height="28"
                                    Padding="0" Click="BtnMinimize_Click" ToolTip="Minimizar"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- FILTER + SEARCH BAR -->
                <Border Background="{StaticResource BgBaseBrush}" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1" Padding="18,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="cboProject" Grid.Column="0"
                                  Style="{StaticResource ModernComboBox}"
                                  DisplayMemberPath="Key"
                                  SelectionChanged="CboProject_SelectionChanged"
                                  ToolTip="Filtrar por proyecto"/>

                        <TextBox x:Name="txtSearch" Grid.Column="2"
                                 Style="{StaticResource ModernTextBox}"
                                 Text="Buscar issue..."
                                 GotFocus="TxtSearch_GotFocus"
                                 LostFocus="TxtSearch_LostFocus"
                                 KeyDown="TxtSearch_KeyDown"
                                 TextChanged="TxtSearch_TextChanged"
                                 ToolTip="Escribe una clave de issue (ej: PROJ-123) o texto"/>

                        <!-- Filter button -->
                        <Button x:Name="btnFilter" Grid.Column="4"
                                Style="{StaticResource NavButton}"
                                Padding="0"
                                Click="BtnFilter_Click" ToolTip="Filtrar por estado">
                            <Grid>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Rectangle Height="2" Width="12" RadiusX="1" RadiusY="1"
                                               Fill="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2.5"/>
                                    <Rectangle Height="2" Width="8"  RadiusX="1" RadiusY="1"
                                               Fill="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2.5"/>
                                    <Rectangle Height="2" Width="4"  RadiusX="1" RadiusY="1"
                                               Fill="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <Ellipse x:Name="FilterActiveDot" Width="7" Height="7"
                                         Fill="{StaticResource AccentBrush}"
                                         HorizontalAlignment="Right" VerticalAlignment="Top"
                                         Margin="0,1,1,0" Visibility="Collapsed"/>
                            </Grid>
                        </Button>

                        <Button Grid.Column="6" Style="{StaticResource NavButton}"
                                Content="↺" FontSize="14" Click="BtnRefresh_Click" ToolTip="Recargar issues"/>
                    </Grid>
                </Border>

                <!-- ISSUES LIST -->
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <Border Background="{StaticResource BgBaseBrush}" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1" Padding="18,6">
                            <Grid>
                                <TextBlock Text="MIS ISSUES" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock x:Name="txtIssueCount" Text="0" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <ScrollViewer x:Name="IssuesScrollViewer"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="IssuesPanel"/>
                        </ScrollViewer>

                        <TextBlock x:Name="txtIssuesEmpty" Text="No se encontraron issues"
                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Padding="0,16" Visibility="Visible"/>

                        <StackPanel x:Name="IssuesLoading" HorizontalAlignment="Center"
                                    Margin="0,12,0,12" Visibility="Collapsed">
                            <TextBlock Text="Cargando..." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- SELECTED ISSUE DETAIL -->
                <Border x:Name="IssuDetailPanel" Visibility="Collapsed"
                        Background="{StaticResource BgBaseBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="18,10">
                    <StackPanel>
                        <TextBlock Text="ISSUE SELECCIONADO" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="IssueKeyBadge" Grid.Column="0" CornerRadius="4"
                                    Padding="6,3" Background="{StaticResource AccentSoftBrush}">
                                <TextBlock x:Name="txtSelectedKey" Text="PROJ-1"
                                           FontSize="12" FontWeight="SemiBold"
                                           FontFamily="Consolas"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </Border>
                            <Border x:Name="StatusBadge" Grid.Column="2" CornerRadius="4"
                                    Padding="6,3" HorizontalAlignment="Left"
                                    Background="{StaticResource GreenSoftBrush}">
                                <TextBlock x:Name="txtSelectedStatus" Text="En progreso"
                                           FontSize="11" Foreground="{StaticResource GreenBrush}"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="txtSelectedSummary" FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- TIME ENTRY FORM -->
                <StackPanel Margin="18,14">
                    <TextBlock Text="HORAS" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource NavButton}" Content="-"
                                FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                                Click="BtnHoursMinus_Click"/>
                        <TextBox x:Name="txtHours" Grid.Column="1" Style="{StaticResource ModernTextBox}"
                                 Text="1.0" TextAlignment="Center" FontFamily="Consolas"
                                 FontSize="20" FontWeight="SemiBold" Margin="6,0"/>
                        <Button Grid.Column="2" Style="{StaticResource NavButton}" Content="+"
                                FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                                Click="BtnHoursPlus_Click"/>
                    </Grid>

                    <UniformGrid Columns="5" Margin="0,4,0,12">
                        <Button Style="{StaticResource QuickHourButton}" Content="0.5" Click="QuickHour_Click" Tag="0.5" Margin="2,0"/>
                        <Button Style="{StaticResource QuickHourButton}" Content="1.0" Click="QuickHour_Click" Tag="1"   Margin="2,0"/>
                        <Button Style="{StaticResource QuickHourButton}" Content="2.0" Click="QuickHour_Click" Tag="2"   Margin="2,0"/>
                        <Button Style="{StaticResource QuickHourButton}" Content="4.0" Click="QuickHour_Click" Tag="4"   Margin="2,0"/>
                        <Button Style="{StaticResource QuickHourButton}" Content="8.0" Click="QuickHour_Click" Tag="8"   Margin="2,0"/>
                    </UniformGrid>

                    <!-- Date navigation -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="FECHA" Style="{StaticResource LabelStyle}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Grid.Column="1" Style="{StaticResource NavButton}" Content="&lt;"
                                Click="BtnDatePrev_Click"/>
                        <Border Grid.Column="2" Background="{StaticResource BgInputBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Margin="4,0">
                            <TextBlock x:Name="txtSelectedDate" FontSize="13" FontFamily="Consolas"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Padding="8,6"/>
                        </Border>
                        <Button Grid.Column="3" Style="{StaticResource NavButton}" Content="&gt;"
                                Click="BtnDateNext_Click"/>
                        <Button Grid.Column="4" Style="{StaticResource GhostButton}"
                                Content="Hoy" FontSize="11" FontWeight="SemiBold"
                                Padding="10,4" Click="BtnDateToday_Click" Margin="6,0,0,0"/>
                    </Grid>

                    <TextBlock Text="NOTAS" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="txtNotes" Style="{StaticResource ModernTextBox}"
                             Height="50" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalContentAlignment="Top" Margin="0,0,0,12"/>

                    <Button x:Name="btnSubmit" Style="{StaticResource AccentButton}"
                            Content="Registrar en Jira" Click="BtnSubmit_Click" Height="40"/>

                    <TextBlock x:Name="txtStatus" FontSize="12" HorizontalAlignment="Center"
                               Margin="0,8,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- DAILY WORKLOGS -->
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                    <StackPanel>

                        <!-- Hours summary -->
                        <Border Background="{StaticResource BgBaseBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1" Padding="18,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="I M P U T A D O" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtJiraHoursToday" Text="0.0"
                                               FontSize="18" FontWeight="SemiBold" FontFamily="Consolas"
                                               Foreground="{StaticResource GreenBrush}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="O B J E T I V O" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtJiraTargetHours" Text="8.0"
                                               FontSize="18" FontWeight="SemiBold" FontFamily="Consolas"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    <Border Width="80" Height="4" CornerRadius="2"
                                            Background="{StaticResource BgElevatedBrush}" Margin="0,4,0,0"
                                            HorizontalAlignment="Center">
                                        <Border x:Name="JiraProgressBar" Height="4" CornerRadius="2"
                                                Background="{StaticResource GreenBrush}"
                                                HorizontalAlignment="Left" Width="0"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Entries header -->
                        <Border Background="{StaticResource BgBaseBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1" Padding="18,6">
                            <Grid>
                                <TextBlock Text="REGISTROS DEL DIA" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock x:Name="txtWorklogCount" Text="0" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <ScrollViewer x:Name="WorklogsScrollViewer" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="WorklogsPanel"/>
                        </ScrollViewer>

                        <TextBlock x:Name="txtWorklogsEmpty" Text="No hay registros para este dia"
                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Padding="0,16" Visibility="Visible"/>

                        <StackPanel x:Name="WorklogsLoading" HorizontalAlignment="Center"
                                    Margin="0,8,0,8" Visibility="Collapsed">
                            <TextBlock Text="Cargando..." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- FILTER POPUP -->
                <Popup x:Name="FilterPopup"
                       Placement="Bottom" VerticalOffset="2"
                       StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                    <Border Background="{StaticResource BgElevatedBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="4" MinWidth="170">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.6" Color="Black"/>
                        </Border.Effect>
                        <StackPanel x:Name="FilterOptionsPanel"/>
                    </Border>
                </Popup>

                <!-- FOOTER -->
                <Border Background="{StaticResource BgBaseBrush}" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0" Padding="18,8" CornerRadius="0,0,16,16">
                    <TextBlock x:Name="txtBaseUrlDisplay" FontSize="10" FontFamily="Consolas"
                               Foreground="{StaticResource TextMutedBrush}" Opacity="0.6"/>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>
